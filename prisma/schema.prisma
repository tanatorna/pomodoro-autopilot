// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Task {
  id                  Int           @id @default(autoincrement())
  roomId              String        @default("default")
  title               String
  priority            Int           @default(0)
  estimatedPomodoros  Int           @default(1)
  completedPomodoros  Int           @default(0)
  status              String        @default("pending") // pending | in-progress | done | backlog
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  slots               ScheduleSlot[]

  @@index([roomId])
}

model Session {
  id                  Int       @id @default(autoincrement())
  roomId              String    @default("default")
  state               String    @default("IDLE") // IDLE | WORK | SHORT_BREAK | LONG_BREAK | PAUSED
  endsAt              DateTime?
  remainingMs         Int?
  origin              String?
  completedPomodoros  Int       @default(0)
  currentTaskId       Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([roomId])
}

model ScheduleSlot {
  id         Int      @id @default(autoincrement())
  roomId     String   @default("default")
  taskId     Int
  task       Task     @relation(fields: [taskId], references: [id])
  slotIndex  Int
  status     String   @default("pending") // pending | completed | voided
  createdAt  DateTime @default(now())

  @@index([roomId])
}
