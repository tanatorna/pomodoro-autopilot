// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Task {
  id                  Int           @id @default(autoincrement())
  roomId              String        @default("default")
  title               String
  priority            Int           @default(0)
  estimatedPomodoros  Int           @default(1)
  completedPomodoros  Int           @default(0)
  status              String        @default("pending") // pending | in-progress | done | backlog
  scheduledFor        DateTime?     // backlog task ปักวันได้ · ถึงวัน → auto-promote เป็น pending
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  slots               ScheduleSlot[]

  @@index([roomId])
}

model Session {
  id                  Int       @id @default(autoincrement())
  roomId              String    @default("default")
  state               String    @default("IDLE") // IDLE | WORK | SHORT_BREAK | LONG_BREAK | PAUSED
  endsAt              DateTime?
  remainingMs         Int?
  origin              String?
  completedPomodoros  Int       @default(0)
  currentTaskId       Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([roomId])
}

model RoomSetting {
  roomId                String   @id
  workMinutes           Int      @default(25)
  shortBreakMinutes     Int      @default(5)
  longBreakMinutes      Int      @default(15)
  pomodorosPerLongBreak Int      @default(4)
  updatedAt             DateTime @updatedAt
}

// สรุปยอดรายวัน (snapshot ตอนปิดวัน: กดเคลียร์ / จบวัน / auto-midnight)
// date = วัน "ที่ถูกปิด" (YYYY-MM-DD local) ไม่ใช่เวลาที่ archive → ตัวเลขแม่นแม้ auto-midnight มาทำวันถัดไป
// upsert แบบ increment: ปิดวันเดียวกันหลายครั้ง → ยอดสะสมรวมกัน
model DaySummary {
  id             Int      @id @default(autoincrement())
  roomId         String   @default("default")
  date           String // YYYY-MM-DD (local)
  totalPomodoros Int      @default(0)
  tasksDone      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([roomId, date])
  @@index([roomId])
}

model ScheduleSlot {
  id         Int      @id @default(autoincrement())
  roomId     String   @default("default")
  taskId     Int
  task       Task     @relation(fields: [taskId], references: [id])
  slotIndex  Int
  status     String   @default("pending") // pending | completed | voided
  createdAt  DateTime @default(now())

  @@index([roomId])
}

// ─── Auth.js (optional Google sign-in) ───────────────────────────
// ใช้ JWT session strategy → ไม่ต้องมี Auth Session table (เลี่ยงชนกับ Session ของ pomodoro)
// roomId = ห้องที่ user นี้ claim ไว้ → sign in ที่เครื่องไหนก็เจอห้องเดิม

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  roomId        String?   // ห้องที่ผูกกับบัญชีนี้
  accounts      Account[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}
